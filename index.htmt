<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Savitri Electronics | Finance Manager</title>
    
    <!-- Google Fonts for Premium Look -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #1e3a8a; /* Deep Premium Blue */
            --secondary: #3b82f6; /* Light Blue */
            --background: #f0f2f5;
            --card-bg: #ffffff;
            --text-main: #1f2937;
            --text-muted: #6b7280;
            --danger: #ef4444;
            --success: #10b981;
        }
        
        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--background);
            color: var(--text-main);
            margin: 0;
            padding: 0;
        }

        /* Navbar */
        .navbar {
            background-color: var(--primary);
            color: white;
            padding: 15px 20px;
            text-align: center;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
        .navbar h2 {
            margin: 0;
            font-size: 22px;
            font-weight: 600;
            letter-spacing: 1px;
        }
        .navbar p {
            margin: 5px 0 0;
            font-size: 12px;
            color: #bfdbfe;
        }

        .container {
            max-width: 800px;
            margin: 20px auto;
            padding: 0 15px;
        }

        .card {
            background: var(--card-bg);
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            margin-bottom: 20px;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            border-bottom: 2px solid #f3f4f6;
            padding-bottom: 10px;
        }
        .card-header h3 {
            margin: 0;
            font-size: 18px;
            color: var(--primary);
        }
        .badge {
            background-color: var(--secondary);
            color: white;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        /* Form Inputs */
        .input-group {
            margin-bottom: 15px;
        }
        .input-group label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 5px;
            color: var(--text-muted);
        }
        input {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 15px;
            font-family: inherit;
            box-sizing: border-box;
            transition: all 0.3s ease;
        }
        input:focus {
            outline: none;
            border-color: var(--secondary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
        }

        /* Search Bar */
        .search-box {
            background: #f9fafb;
            border: 1px solid #e5e7eb;
        }

        button.save-btn {
            width: 100%;
            background-color: var(--primary);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
            margin-top: 10px;
        }
        button.save-btn:hover {
            background-color: #172a6b;
        }

        /* List Items */
        .record-item {
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 10px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            transition: transform 0.2s;
        }
        .record-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }
        .product-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-main);
        }
        .sr-badge {
            background: #fef3c7;
            color: #92400e;
            padding: 2px 8px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 14px;
            display: inline-block;
        }
        .serial-text {
            font-size: 13px;
            color: var(--text-muted);
        }
        
        .btn-use {
            background-color: white;
            color: var(--danger);
            border: 1px solid var(--danger);
            padding: 8px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            margin-top: 5px;
            transition: all 0.2s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn-use:hover {
            background-color: var(--danger);
            color: white;
        }

        /* Loading Spinner */
        .loading {
            text-align: center;
            padding: 20px;
            color: var(--text-muted);
            font-size: 14px;
        }
    </style>
</head>
<body>

    <!-- Top Navbar -->
    <div class="navbar">
        <h2>SAVITRI ELECTRONICS</h2>
        <p>Finance Inventory Manager</p>
    </div>

    <div class="container">
        <!-- Add New Entry Card -->
        <div class="card">
            <div class="card-header">
                <h3>Add Fresh Product</h3>
            </div>
            <div class="input-group">
                <label>Product Details (e.g. LED TV 43")</label>
                <input type="text" id="productName" placeholder="Enter product name..." required>
            </div>
            <div class="input-group">
                <label>Bajaj SR Number</label>
                <input type="text" id="srNumber" placeholder="Enter SR number..." required>
            </div>
            <div class="input-group">
                <label>Serial Number (S/N)</label>
                <input type="text" id="serialNumber" placeholder="Enter product serial number..." required>
            </div>
            <button class="save-btn" id="saveBtn">Save to Database</button>
        </div>

        <!-- Live Inventory Card -->
        <div class="card">
            <div class="card-header">
                <h3>Available Stock</h3>
                <span class="badge" id="totalCount">0 Items</span>
            </div>
            
            <!-- Search Bar -->
            <div class="input-group">
                <input type="text" id="searchInput" class="search-box" placeholder="🔍 Search by Model or SR Number..." onkeyup="filterRecords()">
            </div>

            <div id="recordsList">
                <div class="loading">Loading database...</div>
            </div>
        </div>
    </div>

    <!-- Firebase Code (Module type) -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
        import { getFirestore, collection, addDoc, onSnapshot, deleteDoc, doc, serverTimestamp, query, orderBy } 
        from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyDMxOAPhpgdwIsBB3RQSnitsOqp6njW4cc",
            authDomain: "bajaj-finance-aap.firebaseapp.com",
            projectId: "bajaj-finance-aap",
            storageBucket: "bajaj-finance-aap.firebasestorage.app",
            messagingSenderId: "147678015396",
            appId: "1:147678015396:web:f04e504de17b3bab22db31",
            measurementId: "G-Z6VVGN318K"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);

        // Add Record
        document.getElementById('saveBtn').addEventListener('click', async () => {
            const product = document.getElementById('productName').value;
            const sr = document.getElementById('srNumber').value;
            const serial = document.getElementById('serialNumber').value;
            const btn = document.getElementById('saveBtn');

            if (product && sr && serial) {
                btn.innerText = "Saving...";
                btn.style.opacity = "0.7";
                try {
                    await addDoc(collection(db, "finance_records"), {
                        product: product.toUpperCase(),
                        sr: sr.toUpperCase(),
                        serial: serial.toUpperCase(),
                        timestamp: serverTimestamp()
                    });
                    document.getElementById('productName').value = '';
                    document.getElementById('srNumber').value = '';
                    document.getElementById('serialNumber').value = '';
                } catch (e) {
                    alert("Error: " + e.message);
                }
                btn.innerText = "Save to Database";
                btn.style.opacity = "1";
            } else {
                alert("Please fill all details!");
            }
        });

        // Global Delete Function
        window.deleteRecord = async function(id) {
            if (confirm("Are you sure this item is used/sold? It will be removed permanently.")) {
                await deleteDoc(doc(db, "finance_records", id));
            }
        };

        // Real-time Data Sync
        const q = query(collection(db, "finance_records"), orderBy("timestamp", "desc"));
        onSnapshot(q, (querySnapshot) => {
            const list = document.getElementById('recordsList');
            const countBadge = document.getElementById('totalCount');
            list.innerHTML = '';
            
            // Update total count
            countBadge.innerText = querySnapshot.size + " Items";

            if (querySnapshot.empty) {
                list.innerHTML = '<div class="loading">No records found. Add a new product above.</div>';
                return;
            }

            querySnapshot.forEach((doc) => {
                const data = doc.data();
                // Adding 'record-card' class for search filtering
                list.innerHTML += `
                    <div class="record-item record-card">
                        <div class="product-title">${data.product}</div>
                        <div>
                            <span class="sr-badge">SR: ${data.sr}</span>
                        </div>
                        <div class="serial-text">S/N: ${data.serial}</div>
                        <button class="btn-use" onclick="deleteRecord('${doc.id}')">Use & Delete Item</button>
                    </div>
                `;
            });
        });

        // Search Function
        window.filterRecords = function() {
            let input = document.getElementById('searchInput').value.toUpperCase();
            let cards = document.getElementsByClassName('record-card');
            
            for (let i = 0; i < cards.length; i++) {
                let text = cards[i].innerText.toUpperCase();
                if (text.indexOf(input) > -1) {
                    cards[i].style.display = "";
                } else {
                    cards[i].style.display = "none";
                }
            }
        }
    </script>
</body>
</html>
